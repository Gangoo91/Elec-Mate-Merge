# Elec-AI MCP Server — Environment Variables
# Copy to .env and fill in values

# ── Server ──────────────────────────────────────────────────────────────
MCP_PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# Transport: 'http' (Express server, default) or 'stdio' (stdin/stdout for OpenClaw)
MCP_TRANSPORT=http

# User JWT for stdio mode (required when MCP_TRANSPORT=stdio)
# In HTTP mode, JWT comes from the Authorization header per request
MCP_USER_JWT=

# Comma-separated allowed CORS origins (HTTP mode, default: * for development)
CORS_ORIGINS=*

# ── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://jtwygbeceundfgnkirof.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
