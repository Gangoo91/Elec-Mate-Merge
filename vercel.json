{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/.well-known/ai-plugin.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/openapi.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-snippet:-1" }
      ]
    },
    {
      "source": "/api/public/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, max-age=300, stale-while-revalidate=86400"
        },
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "X-Elec-Mate", "value": "https://www.elec-mate.com" }
      ]
    },
    {
      "source": "/.well-known/llm-facts.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-snippet:-1" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-snippet:-1" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/cheatsheet.pdf",
      "destination": "https://jtwygbeceundfgnkirof.supabase.co/storage/v1/object/public/lead-magnets/bs7671-a4-2026-cheatsheet.pdf",
      "permanent": false
    },
    {
      "source": "/cheatsheet",
      "destination": "https://jtwygbeceundfgnkirof.supabase.co/storage/v1/object/public/lead-magnets/bs7671-a4-2026-cheatsheet.pdf",
      "permanent": false
    },
    {
      "source": "/battery-storage-installation",
      "destination": "/guides/battery-storage-installation",
      "permanent": true
    },
    {
      "source": "/testing-sequence-guide",
      "destination": "/guides/testing-sequence-guide",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-a-application-of-knowledge",
      "destination": "/guides/am2-section-e-online-knowledge-test",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-b-safe-isolation",
      "destination": "/guides/am2-section-c-safe-isolation",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-c-wiring-systems-installation",
      "destination": "/guides/am2-section-a-composite-installation",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-d-continuity-and-insulation-testing",
      "destination": "/guides/am2-section-b-inspection-testing-certification",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-e-initial-verification-and-periodic-inspection",
      "destination": "/guides/am2-section-b-inspection-testing-certification",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-f-fault-diagnosis",
      "destination": "/guides/am2-section-d-fault-diagnosis",
      "permanent": true
    },
    {
      "source": "/guides/am2-section-g-industry-knowledge",
      "destination": "/guides/am2-section-e-online-knowledge-test",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-1-introduction",
      "destination": "/guides/am2-overview-and-structure",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-2-health-safety-documentation",
      "destination": "/guides/am2-section-c-safe-isolation",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-3-installation-tasks",
      "destination": "/guides/am2-section-a-composite-installation",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-4-inspection-and-testing",
      "destination": "/guides/am2-section-b-inspection-testing-certification",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-5-fault-diagnosis-and-rectification",
      "destination": "/guides/am2-section-d-fault-diagnosis",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-6-online-knowledge-test",
      "destination": "/guides/am2-section-e-online-knowledge-test",
      "permanent": true
    },
    {
      "source": "/guides/am2-module-7-exam-strategy-and-success-tips",
      "destination": "/guides/am2-overview-and-structure",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/" },
    { "source": "/terms", "destination": "/" },
    { "source": "/cookies", "destination": "/" },
    { "source": "/acceptable-use", "destination": "/" },
    { "source": "/support", "destination": "/" },
    {
      "source": "/((?!assets/|api/|llms\\.txt|llms-full\\.txt|robots\\.txt|sitemap.*\\.xml|\\.well-known/|.+\\.[a-zA-Z0-9]+$).*)",
      "destination": "/"
    }
  ]
}
