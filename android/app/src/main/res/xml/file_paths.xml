<?xml version="1.0" encoding="utf-8"?>
<!--
  FileProvider scope — limited to app-private directories that are auto-cleared
  on uninstall. The previous <external-path path="."/> rule granted any consumer
  of a content:// URI access to the entire external storage root, which Play
  Console flags as overly broad. The Capacitor Camera plugin writes captures to
  cache/ and the Filesystem plugin uses external-files-path; both are covered.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
    <external-cache-path name="external_cache" path="." />
    <external-files-path name="external_files" path="." />
</paths>