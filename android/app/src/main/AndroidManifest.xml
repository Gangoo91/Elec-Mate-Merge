<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/full_backup_content"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTop"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="elec-mate.com" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
          FCM notification icon + accent colour. Android 5+ extracts the alpha
          channel from the notification icon and tints it with the supplied
          colour. Without these meta-data lines, FCM falls back to the launcher
          icon (rendered as a generic grey silhouette). ic_notification is a
          white-on-transparent bulb mark sized for the status bar; colorAccent
          is the brand yellow (#facc15) defined in colors.xml.
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/colorAccent" />
    </application>

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Voice input / audio recording — required by dictation features -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Push notifications — required for Android 13+ (API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera — photo capture for certificates, site safety, inspections -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!--
      Photo selection uses the Android Photo Picker (@capacitor/camera v8),
      which needs NO media permission on Android 13+. READ_MEDIA_IMAGES /
      READ_MEDIA_VIDEO are intentionally NOT declared — Google Play's Photo &
      Video Permissions policy disallows them for one-time/infrequent access.
      Legacy storage read for Android <=12 only: -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />

    <!-- Biometric authentication — Face ID / Touch ID / Fingerprint login -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Google Play Billing — required for RevenueCat in-app purchases / subscriptions -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Advertising ID — required for targetSdk 33+ if any SDK reads the AAID.
         RevenueCat (attribution) and Firebase Analytics both read it. Without
         this permission, Android 13+ returns a zeroed-out AAID. Must match the
         "Advertising ID" declaration in Play Console Data Safety. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!--
      Hardware features declared as optional so Play Store does NOT filter the
      app out from devices without them. Without required=false the app would
      be hidden from Chromebooks and tablets that lack a microphone or camera.
    -->
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.camera.flash" android:required="false" />
</manifest>
